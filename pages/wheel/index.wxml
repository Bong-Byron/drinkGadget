<view class="wheel-page">
  <view class="brick-bg"></view>
  <view class="top-bar">
    <view class="back-button" catchtap="goBack">
      <view class="back-icon"></view>
    </view>
    <view class="nav-title">{{title}}</view>
  </view>

  <view class="result-bubble">
    <text>{{result}}</text>
    <view class="bubble-arrow"></view>
  </view>

  <view class="wheel-stage">
    <view class="wheel-glow"></view>
    <view class="wheel-board" style="{{wheelStyle}}">
      <view
        wx:for="{{wheelItems}}"
        wx:key="*this"
        class="wheel-label label-{{index}}"
        data-index="{{index}}"
        catchtap="openEdit"
      >
        {{item}}
      </view>
    </view>
    <view class="wheel-border"></view>
    <view class="center-button" catchtap="spin">
      <view class="play-icon"></view>
    </view>
  </view>

  <view class="edit-hint">
    <text>{{hintText}}</text>
    <text class="vip-pill">{{vipText}}</text>
  </view>

  <view class="ad-card">{{adText}}</view>

  <view wx:if="{{editVisible}}" class="edit-mask" catchtap="closeEdit">
    <view class="edit-panel" catchtap="noop">
      <view class="edit-title">{{editTitle}}</view>
      <input
        class="edit-input"
        value="{{editValue}}"
        maxlength="6"
        focus="{{true}}"
        placeholder="{{editPlaceholder}}"
        placeholder-class="edit-placeholder"
        bindinput="handleEditInput"
      />
      <view class="edit-count">{{editValue.length}}/6</view>
      <view class="edit-actions">
        <button class="edit-btn ghost" catchtap="closeEdit">{{cancelText}}</button>
        <button class="edit-btn primary" catchtap="saveEdit">{{saveText}}</button>
      </view>
    </view>
  </view>
</view>
