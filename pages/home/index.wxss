.home {
  padding-top: 26rpx;
}

.hero {
  position: relative;
  overflow: hidden;
  margin: 0 -28rpx;
  padding: 34rpx 40rpx 42rpx;
  border-bottom: 1rpx solid rgba(88, 78, 160, 0.32);
  background:
    radial-gradient(circle at 18% 28%, rgba(0, 214, 255, 0.18), transparent 22%),
    radial-gradient(circle at 86% 0%, rgba(255, 71, 166, 0.13), transparent 26%),
    linear-gradient(155deg, #12052d 0%, #0a0620 62%, #140726 100%);
}

.hero::before {
  content: "";
  position: absolute;
  inset: 0;
  opacity: 0.24;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.08) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(255, 255, 255, 0.08) 1rpx, transparent 1rpx);
  background-size: 12rpx 12rpx;
}

.hero-top,
.user-row {
  position: relative;
  z-index: 1;
}

.hero-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.settings {
  display: flex;
  align-items: center;
  gap: 12rpx;
  height: 58rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 58rpx;
}

.settings-icon {
  color: #dcd9ff;
  font-size: 42rpx;
}

.mini-menu {
  width: 178rpx;
  height: 62rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.34);
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 62rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.08);
}

.user-row {
  display: flex;
  align-items: center;
  gap: 22rpx;
  margin-top: 44rpx;
}

.avatar-ring {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: conic-gradient(from 220deg, #7c4dff, #00d6ff, #ffffff, #7c4dff);
  box-shadow: 0 0 28rpx rgba(0, 214, 255, 0.42);
}

.avatar-face {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  color: #817a9f;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 96rpx;
  text-align: center;
  background: #f5f1ff;
}

.user-copy {
  flex: 1;
}

.user-name {
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1.15;
}

.vip-pill {
  display: inline-block;
  margin-top: 10rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  color: #4d2d03;
  font-size: 22rpx;
  font-weight: 900;
  background: #ffd98a;
}

.profile-button {
  width: 118rpx;
  height: 58rpx;
  border: 1rpx solid rgba(0, 214, 255, 0.46);
  border-radius: 999rpx;
  color: #72efff;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 58rpx;
  text-align: center;
  background: rgba(0, 214, 255, 0.08);
}

.game-section {
  margin-top: 34rpx;
}

.section-title {
  position: relative;
  display: inline-flex;
  align-items: center;
  min-width: 210rpx;
  height: 58rpx;
  padding-left: 24rpx;
  color: #9b7cff;
  font-size: 30rpx;
  font-weight: 900;
  background: linear-gradient(90deg, rgba(34, 75, 170, 0.48), rgba(34, 75, 170, 0));
}

.section-title::after {
  content: "";
  position: absolute;
  right: 0;
  bottom: 0;
  width: 86rpx;
  height: 2rpx;
  background: rgba(0, 214, 255, 0.64);
}

.game-scroll {
  width: 100%;
  margin-top: 18rpx;
  white-space: nowrap;
}

.scroll-inner {
  display: inline-flex;
  gap: 28rpx;
  padding: 8rpx 28rpx 8rpx 0;
}
