<view class="screen home">
  <view class="hero">
    <view class="user-row">
      <view class="avatar-ring">
        <view class="avatar-face">{{avatarText}}</view>
      </view>
      <view class="user-copy">
        <view class="user-name">{{userName}}</view>
        <view class="vip-pill">{{modeText}}</view>
      </view>
      <button class="profile-button" bindtap="goProfile">{{profileText}}</button>
    </view>
  </view>

  <view wx:for="{{sections}}" wx:key="title" class="game-section">
    <view class="section-title">{{item.title}}</view>
    <scroll-view class="game-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="scroll-inner">
        <game-card
          wx:for="{{item.games}}"
          wx:for-item="game"
          wx:key="id"
          icon-path="{{game.iconPath}}"
          title="{{game.title}}"
          desc="{{game.desc}}"
          path="{{game.path}}"
          bind:select="handleSelect"
        />
      </view>
    </scroll-view>
  </view>

  <ad wx:if="{{bannerAdUnitId}}" unit-id="{{bannerAdUnitId}}" />
  <view wx:else class="ad-placeholder">{{adText}}</view>
</view>
