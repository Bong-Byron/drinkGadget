.touch-zone {
  position: relative;
  height: 720rpx;
  margin-top: 34rpx;
  overflow: hidden;
  border: 2rpx solid rgba(0, 229, 255, 0.48);
  border-radius: 16rpx;
  background: radial-gradient(circle at center, rgba(0, 229, 255, 0.12), rgba(255, 0, 255, 0.08) 58%, rgba(255, 255, 255, 0.04));
}

.touch-hint {
  position: absolute;
  top: 50%;
  left: 0;
  width: 100%;
  transform: translateY(-50%);
  color: rgba(255, 255, 255, 0.32);
  font-size: 46rpx;
  font-weight: 900;
  text-align: center;
}

.touch-dot {
  position: absolute;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  color: #071022;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 88rpx;
  text-align: center;
  box-shadow: 0 0 32rpx currentColor;
}
