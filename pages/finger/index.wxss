.finger-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background:
    radial-gradient(circle at 78% 82%, rgba(21, 231, 180, 0.08), transparent 24%),
    linear-gradient(180deg, #020403 0%, #020303 58%, #03110f 100%);
}

.touch-layer {
  position: absolute;
  z-index: 1;
  inset: 0;
}

.back-button {
  position: absolute;
  z-index: 20;
  top: 62rpx;
  left: 28rpx;
  width: 78rpx;
  height: 78rpx;
}

.back-icon {
  width: 28rpx;
  height: 28rpx;
  margin: 24rpx 0 0 24rpx;
  border-left: 7rpx solid #ffffff;
  border-bottom: 7rpx solid #ffffff;
  transform: rotate(45deg);
}

.touch-marker {
  position: absolute;
  z-index: 8;
  width: 110px;
  height: 110px;
  pointer-events: none;
}

.marker-core {
  position: absolute;
  left: 31px;
  top: 31px;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: var(--touch-color);
  box-shadow: 0 0 22px var(--touch-color);
  animation: coreBreath 680ms ease-in-out infinite alternate;
}

.marker-ring {
  position: absolute;
  left: 19px;
  top: 19px;
  width: 72px;
  height: 72px;
  border: 3px solid var(--touch-color);
  border-radius: 50%;
  opacity: 0.36;
  box-shadow: 0 0 20px var(--touch-color);
  animation: ringPulse 900ms ease-in-out infinite;
}

.ring-b {
  left: 8px;
  top: 8px;
  width: 94px;
  height: 94px;
  opacity: 0.18;
  animation-delay: 180ms;
}

.marker-dot {
  position: absolute;
  width: 9px;
  height: 9px;
  border-radius: 50%;
  background: var(--touch-color);
  box-shadow: 0 0 10px var(--touch-color), 0 0 18px var(--touch-color);
  animation: dotBlink 760ms ease-in-out infinite alternate;
}

.dot-0 { left: 51px; top: 0; }
.dot-1 { left: 70px; top: 5px; width: 7px; height: 7px; animation-delay: 50ms; }
.dot-2 { left: 88px; top: 17px; animation-delay: 100ms; }
.dot-3 { left: 101px; top: 38px; width: 11px; height: 11px; animation-delay: 150ms; }
.dot-4 { left: 102px; top: 62px; animation-delay: 200ms; }
.dot-5 { left: 91px; top: 84px; width: 7px; height: 7px; animation-delay: 250ms; }
.dot-6 { left: 72px; top: 100px; animation-delay: 300ms; }
.dot-7 { left: 49px; top: 104px; width: 7px; height: 7px; animation-delay: 350ms; }
.dot-8 { left: 25px; top: 97px; animation-delay: 400ms; }
.dot-9 { left: 8px; top: 80px; width: 7px; height: 7px; animation-delay: 450ms; }
.dot-10 { left: -1px; top: 57px; animation-delay: 500ms; }
.dot-11 { left: 2px; top: 32px; width: 7px; height: 7px; animation-delay: 550ms; }
.dot-12 { left: 17px; top: 12px; animation-delay: 600ms; }
.dot-13 { left: 35px; top: 3px; width: 7px; height: 7px; animation-delay: 650ms; }
.dot-14 { left: 121px; top: 44px; width: 6px; height: 6px; animation-delay: 700ms; }
.dot-15 { left: 116px; top: 75px; width: 6px; height: 6px; animation-delay: 750ms; }
.dot-16 { left: 77px; top: 119px; width: 6px; height: 6px; animation-delay: 800ms; }
.dot-17 { left: 20px; top: 117px; width: 6px; height: 6px; animation-delay: 850ms; }

.jumping {
  animation: markerJump 340ms ease-in-out infinite alternate;
}

.selected {
  z-index: 12;
}

.selected .marker-core {
  background: #ffffff;
  transform: scale(1.1);
}

.selected .marker-ring {
  opacity: 0.92;
  border-width: 5px;
  animation: selectedPulse 440ms ease-in-out infinite alternate;
}

.winner {
  z-index: 18;
  animation: winnerBounce 560ms ease-in-out infinite alternate;
}

.winner .marker-core {
  width: 76px;
  height: 76px;
  left: 17px;
  top: 17px;
  background: #ffffff;
  box-shadow: 0 0 26px #ffffff, 0 0 70px var(--touch-color);
}

.winner .marker-ring {
  opacity: 1;
  border-width: 8px;
  animation: winnerRing 520ms ease-in-out infinite alternate;
}

.winner .ring-b {
  opacity: 0.5;
}

.winner .marker-dot {
  background: #ffffff;
  box-shadow: 0 0 18px #ffffff, 0 0 34px var(--touch-color);
  animation-duration: 300ms;
}

.winner-halo {
  display: none;
  position: absolute;
  left: -38px;
  top: -38px;
  width: 186px;
  height: 186px;
  border: 5px solid var(--touch-color);
  border-radius: 50%;
  opacity: 0;
  box-shadow: 0 0 50px var(--touch-color), inset 0 0 46px var(--touch-color);
  pointer-events: none;
}

.winner .winner-halo {
  display: block;
  animation: winnerHalo 700ms ease-in-out infinite alternate;
}

.pick-button {
  position: absolute;
  z-index: 30;
  top: 50%;
  left: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 300rpx;
  transform: translate(-50%, -50%);
  border-radius: 16rpx;
  background: linear-gradient(180deg, #f6f6f6 0%, #dddddd 100%);
  box-shadow: 0 14rpx 34rpx rgba(0, 0, 0, 0.34);
}

.pick-text {
  display: block;
  width: 250rpx;
  color: #4a4a4a;
  font-size: 38rpx;
  font-style: italic;
  font-weight: 500;
  line-height: 1;
  letter-spacing: 0;
  text-align: center;
  transform: rotate(90deg);
  white-space: nowrap;
}

.picking-state {
  position: absolute;
  z-index: 4;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
}

.beat-dot {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background: #13F15B;
  box-shadow: 0 0 22rpx rgba(19, 241, 91, 0.9);
  animation: beat 380ms ease-in-out infinite;
}

.help-button {
  position: absolute;
  z-index: 34;
  right: 36rpx;
  bottom: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 84rpx;
  height: 84rpx;
  border: 2rpx solid rgba(124, 244, 255, 0.82);
  border-radius: 50%;
  background: rgba(5, 17, 18, 0.76);
  box-shadow: 0 0 18rpx rgba(124, 244, 255, 0.5), inset 0 0 14rpx rgba(124, 244, 255, 0.12);
}

.help-question {
  color: #7cf4ff;
  font-size: 34rpx;
  font-weight: 900;
  line-height: 34rpx;
  text-shadow: 0 0 10rpx rgba(124, 244, 255, 0.78);
}

.help-text {
  margin-top: 2rpx;
  color: rgba(220, 252, 255, 0.82);
  font-size: 18rpx;
  font-weight: 700;
  line-height: 20rpx;
}

.guide-mask {
  position: fixed;
  z-index: 60;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 42rpx;
  background: rgba(0, 0, 0, 0.72);
}

.guide-card {
  width: 100%;
  max-width: 620rpx;
  padding: 38rpx;
  border: 1rpx solid rgba(124, 244, 255, 0.28);
  border-radius: 22rpx;
  background: rgba(16, 17, 22, 0.96);
}

.guide-title {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 900;
}

.guide-line {
  display: flex;
  gap: 18rpx;
  margin-top: 20rpx;
  color: rgba(255, 255, 255, 0.76);
  font-size: 27rpx;
  font-weight: 600;
  line-height: 1.5;
}

.guide-index {
  flex: none;
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  color: #061214;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 38rpx;
  text-align: center;
  background: #72efff;
}

.guide-copy {
  flex: 1;
}

.guide-close {
  height: 78rpx;
  margin-top: 30rpx;
  border-radius: 999rpx;
  color: #020403;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 78rpx;
  background: #72efff;
}

.penalty-page {
  position: absolute;
  z-index: 40;
  inset: 0;
  min-height: 100vh;
  padding: 210rpx 52rpx 48rpx;
  overflow: hidden;
  background:
    radial-gradient(circle at 50% 32%, rgba(255, 255, 255, 0.08), transparent 28%),
    linear-gradient(180deg, rgba(0, 0, 0, 0.42), rgba(0, 0, 0, 0.88)),
    #111;
}

.brick-bg {
  position: absolute;
  inset: 0;
  opacity: 0.34;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.08) 2rpx, transparent 2rpx),
    linear-gradient(90deg, rgba(255, 255, 255, 0.08) 2rpx, transparent 2rpx);
  background-size: 92rpx 42rpx;
}

.penalty-title {
  position: relative;
  z-index: 1;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 900;
  line-height: 1.25;
  text-align: center;
  text-shadow: 0 0 16rpx rgba(255, 255, 255, 0.76);
}

.card-grid {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 54rpx 78rpx;
  margin-top: 58rpx;
}

.punish-card {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.card-face {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 176rpx;
  height: 216rpx;
  border: 6rpx solid #050505;
  border-radius: 18rpx;
  background: var(--card-color);
  box-shadow: 0 0 18rpx var(--card-color), 0 16rpx 0 rgba(0, 0, 0, 0.82), 0 24rpx 0 rgba(0, 0, 0, 0.55);
}

.card-face::after {
  content: "";
  position: absolute;
  inset: 18rpx;
  border: 5rpx solid #050505;
  border-radius: 10rpx;
}

.corner,
.modal-corner {
  position: absolute;
  z-index: 2;
  width: 34rpx;
  height: 34rpx;
  border: 9rpx solid #050505;
  border-radius: 50%;
  background: var(--card-color);
}

.left-top { left: 12rpx; top: 12rpx; border-right-color: transparent; border-bottom-color: transparent; }
.right-top { right: 12rpx; top: 12rpx; border-left-color: transparent; border-bottom-color: transparent; }
.left-bottom { left: 12rpx; bottom: 12rpx; border-right-color: transparent; border-top-color: transparent; }
.right-bottom { right: 12rpx; bottom: 12rpx; border-left-color: transparent; border-top-color: transparent; }

.punish-icon {
  position: relative;
  z-index: 3;
  min-width: 88rpx;
  height: 88rpx;
  border-radius: 10rpx;
  color: #050505;
  font-size: 64rpx;
  font-weight: 900;
  line-height: 88rpx;
  text-align: center;
}

.punish-name {
  margin-top: 24rpx;
  color: var(--card-color);
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1;
  text-shadow: 0 0 14rpx var(--card-color);
}

.restart-button {
  position: relative;
  z-index: 1;
  width: 324rpx;
  height: 86rpx;
  margin: 62rpx auto 0;
  border: 6rpx solid #ffffff;
  border-radius: 999rpx;
  color: #050505;
  font-size: 32rpx;
  font-weight: 900;
  line-height: 74rpx;
  text-align: center;
  background: #ffffff;
  box-shadow: 0 0 18rpx rgba(255, 255, 255, 0.62);
}

.feedback {
  position: relative;
  z-index: 1;
  margin-top: 34rpx;
  color: rgba(255, 255, 255, 0.28);
  font-size: 24rpx;
  line-height: 1.4;
  text-align: center;
}

.punish-mask {
  position: fixed;
  z-index: 80;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 70rpx;
  background: rgba(0, 0, 0, 0.78);
}

.punish-modal {
  position: relative;
  width: 560rpx;
  min-height: 600rpx;
  padding: 118rpx 54rpx 54rpx;
  border: 7rpx solid #050505;
  border-radius: 34rpx;
  background: var(--modal-color);
  box-shadow: 0 0 26rpx var(--modal-color);
}

.punish-modal::after {
  content: "";
  position: absolute;
  inset: 28rpx;
  border: 5rpx solid #050505;
  border-radius: 20rpx;
  pointer-events: none;
}

.modal-corner {
  background: var(--modal-color);
}

.modal-content {
  position: relative;
  z-index: 2;
  color: #050505;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.45;
  text-align: center;
}

.modal-action {
  position: relative;
  z-index: 2;
  width: 320rpx;
  margin: 118rpx auto 0;
  padding-bottom: 14rpx;
  border-bottom: 3rpx solid rgba(255, 255, 255, 0.86);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
  text-align: center;
}

.change-button {
  position: relative;
  z-index: 2;
  width: 204rpx;
  height: 76rpx;
  margin: 42rpx auto 0;
  border-radius: 999rpx;
  color: #050505;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 76rpx;
  text-align: center;
  background: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.18);
}

.modal-close {
  position: absolute;
  bottom: 180rpx;
  left: 50%;
  transform: translateX(-50%);
  color: rgba(255, 255, 255, 0.78);
  font-size: 82rpx;
  font-weight: 300;
  line-height: 1;
}

@keyframes dotBlink {
  from { transform: scale(0.7); opacity: 0.5; }
  to { transform: scale(1.25); opacity: 1; }
}

@keyframes coreBreath {
  from { transform: scale(0.96); }
  to { transform: scale(1.08); }
}

@keyframes ringPulse {
  0% { transform: scale(0.9); opacity: 0.25; }
  100% { transform: scale(1.12); opacity: 0.5; }
}

@keyframes selectedPulse {
  from { transform: scale(1.03); box-shadow: 0 0 22px var(--touch-color); }
  to { transform: scale(1.3); box-shadow: 0 0 42px var(--touch-color); }
}

@keyframes winnerRing {
  from { transform: scale(1.16); box-shadow: 0 0 34px var(--touch-color); }
  to { transform: scale(1.95); box-shadow: 0 0 96px var(--touch-color); }
}

@keyframes winnerBounce {
  from { transform: scale(1.08); }
  to { transform: scale(1.45); }
}

@keyframes winnerHalo {
  from { transform: scale(0.72); opacity: 0.22; }
  to { transform: scale(1.18); opacity: 0.72; }
}

@keyframes markerJump {
  from { transform: translateY(0) scale(1); }
  to { transform: translateY(-10px) scale(1.03); }
}

@keyframes beat {
  0%, 100% { transform: scale(0.75); opacity: 0.5; }
  50% { transform: scale(1.35); opacity: 1; }
}
