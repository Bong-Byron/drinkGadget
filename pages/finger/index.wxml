<view class="finger-page">
  <view
    wx:if="{{phase !== 'penalty'}}"
    class="touch-layer"
    catchtouchstart="handleTouchStart"
    catchtouchmove="handleTouchMove"
    catchtouchend="handleTouchEnd"
    catchtouchcancel="handleTouchEnd"
  ></view>

  <button class="back-button" bindtap="goBack" catchtouchstart="noop" catchtouchmove="noop" catchtouchend="noop" aria-label="back">
    <view class="back-icon"></view>
  </button>

  <view
    wx:if="{{phase !== 'penalty'}}"
    wx:for="{{touches}}"
    wx:for-item="touch"
    wx:key="id"
    class="touch-marker {{selectedId === touch.id ? 'selected' : ''}} {{phase === 'running' ? 'jumping' : ''}} {{phase === 'done' && selectedId === touch.id ? 'winner' : ''}}"
    style="left: {{touch.x}}px; top: {{touch.y}}px; --touch-color: {{touch.color}}; animation-delay: {{touch.delay}};"
  >
    <view class="marker-core"></view>
    <view class="winner-halo"></view>
    <view
      wx:for="{{touch.dots}}"
      wx:for-item="dot"
      wx:key="*this"
      class="marker-dot dot-{{dot}}"
    ></view>
    <view class="marker-ring ring-a"></view>
    <view class="marker-ring ring-b"></view>
  </view>

  <view
    wx:if="{{phase !== 'running' && phase !== 'done' && phase !== 'penalty'}}"
    class="pick-button"
    catchtap="startPick"
    catchtouchstart="startPickByTouch"
  >
    <text class="pick-text">PICK FINGER</text>
  </view>

  <view wx:if="{{phase === 'running'}}" class="picking-state">
    <view class="beat-dot"></view>
  </view>

  <view wx:if="{{phase !== 'penalty'}}" class="help-button" catchtap="toggleGuide">
    <text class="help-question">?</text>
    <text class="help-text">{{helpText}}</text>
  </view>

  <view wx:if="{{showGuide}}" class="guide-mask" catchtap="toggleGuide">
    <view class="guide-card" catchtap="noop">
      <view class="guide-title">{{guideTitle}}</view>
      <view wx:for="{{guideLines}}" wx:key="*this" class="guide-line">
        <text class="guide-index">{{index + 1}}</text>
        <text class="guide-copy">{{item}}</text>
      </view>
      <button class="guide-close" catchtap="toggleGuide">{{guideCloseText}}</button>
    </view>
  </view>

  <view wx:if="{{phase === 'penalty'}}" class="penalty-page">
    <view class="brick-bg"></view>
    <view class="penalty-title">{{penaltyTitle}}</view>
    <view class="card-grid">
      <view
        wx:for="{{punishmentCards}}"
        wx:key="id"
        class="punish-card"
        style="--card-color: {{item.color}};"
        data-id="{{item.id}}"
        catchtap="selectPunishment"
      >
        <view class="card-face">
          <view class="corner left-top"></view>
          <view class="corner right-top"></view>
          <view class="corner left-bottom"></view>
          <view class="corner right-bottom"></view>
          <view class="punish-icon">{{item.icon}}</view>
        </view>
        <view class="punish-name">{{item.title}}</view>
      </view>
    </view>
    <button class="restart-button" catchtap="resetPick">{{againText}}</button>
    <view class="feedback">{{feedbackText}}</view>
  </view>

  <view wx:if="{{selectedPunishment}}" class="punish-mask" catchtap="closePunishment">
    <view class="punish-modal" style="--modal-color: {{selectedPunishment.color}};" catchtap="noop">
      <view class="modal-corner left-top"></view>
      <view class="modal-corner right-top"></view>
      <view class="modal-corner left-bottom"></view>
      <view class="modal-corner right-bottom"></view>
      <view class="modal-content">{{selectedPunishment.content}}</view>
      <view class="modal-action">{{selectedPunishment.action}}</view>
      <button class="change-button" catchtap="changePunishment">{{changeText}}</button>
    </view>
    <view class="modal-close">×</view>
  </view>
</view>
