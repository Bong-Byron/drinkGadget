<view class="screen">
  <view class="page-title">{{title}}</view>
  <view class="page-subtitle">{{subtitle}}</view>

  <view class="section">
    <countdown seconds="{{seconds}}" label="{{running ? runningLabel : readyLabel}}" />
  </view>

  <view class="section">
    <neon-button text="{{running ? runningText : startText}}" disabled="{{running}}" type="danger" bind:tap="start" />
  </view>

  <result-modal visible="{{modalVisible}}" title="{{modalTitle}}" content="{{result}}" bind:confirm="closeModal" />
</view>
