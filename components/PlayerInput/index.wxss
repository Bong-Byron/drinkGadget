.player-input {
  padding: 26rpx;
  border: 1rpx solid rgba(138, 43, 226, 0.48);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.06);
}

.input-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.input-title {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.input-count {
  color: #00E5FF;
  font-size: 24rpx;
}

.input-box {
  width: 100%;
  height: 180rpx;
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 14rpx;
  color: #ffffff;
  font-size: 28rpx;
  line-height: 1.45;
  background: rgba(2, 0, 16, 0.72);
}

.placeholder,
.input-tip {
  color: rgba(255, 255, 255, 0.42);
}

.input-tip {
  margin-top: 14rpx;
  font-size: 22rpx;
}
