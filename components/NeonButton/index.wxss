.neon-button {
  width: 100%;
  height: 92rpx;
  border-radius: 16rpx;
  color: #081022;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 92rpx;
  text-align: center;
  background: #00E5FF;
  box-shadow: 0 0 28rpx rgba(0, 229, 255, 0.55);
  transition: transform 200ms ease, opacity 200ms ease;
}

.secondary {
  color: #ffffff;
  border: 1rpx solid rgba(0, 229, 255, 0.42);
  background: rgba(0, 229, 255, 0.1);
  box-shadow: none;
}

.danger {
  color: #ffffff;
  background: #FF00FF;
  box-shadow: 0 0 28rpx rgba(255, 0, 255, 0.52);
}

.disabled {
  opacity: 0.45;
}
