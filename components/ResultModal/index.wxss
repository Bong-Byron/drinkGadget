.result-modal {
  width: 620rpx;
  padding: 44rpx 36rpx 36rpx;
  border: 1rpx solid rgba(0, 229, 255, 0.55);
  border-radius: 16rpx;
  background: #120733;
  box-shadow: 0 0 52rpx rgba(138, 43, 226, 0.42);
}

.modal-mask {
  position: fixed;
  z-index: 99;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  background: rgba(3, 0, 18, 0.78);
}

.modal-title {
  color: #00E5FF;
  font-size: 34rpx;
  font-weight: 800;
  text-align: center;
}

.modal-content {
  margin-top: 28rpx;
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.35;
  text-align: center;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.modal-button {
  flex: 1;
  height: 82rpx;
  border-radius: 16rpx;
  color: #081022;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 82rpx;
  text-align: center;
  background: #00E5FF;
}

.ghost {
  color: #ffffff;
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  background: rgba(255, 255, 255, 0.08);
}
