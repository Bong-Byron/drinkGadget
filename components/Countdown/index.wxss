.countdown {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 300rpx;
  border: 1rpx solid rgba(255, 0, 255, 0.35);
  border-radius: 16rpx;
  background: rgba(255, 0, 255, 0.08);
  box-shadow: inset 0 0 34rpx rgba(255, 0, 255, 0.12);
}

.count-label {
  color: rgba(255, 255, 255, 0.68);
  font-size: 26rpx;
}

.count-value {
  margin-top: 12rpx;
  color: #00E5FF;
  font-size: 126rpx;
  font-weight: 900;
  line-height: 1;
  text-shadow: 0 0 30rpx rgba(0, 229, 255, 0.8);
}
