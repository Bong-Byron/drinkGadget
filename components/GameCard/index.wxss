.game-card {
  position: relative;
  min-height: 236rpx;
  padding: 28rpx;
  overflow: hidden;
  border: 1rpx solid rgba(0, 229, 255, 0.35);
  border-radius: 16rpx;
  background: rgba(14, 8, 45, 0.88);
  box-shadow: 0 0 22rpx rgba(0, 229, 255, 0.18);
}

.card-glow {
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: rgba(255, 0, 255, 0.18);
  filter: blur(8rpx);
}

.card-icon {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  border: 1rpx solid rgba(255, 0, 255, 0.45);
  border-radius: 16rpx;
  color: #00E5FF;
  font-size: 40rpx;
  line-height: 70rpx;
  text-align: center;
  text-shadow: 0 0 18rpx rgba(0, 229, 255, 0.85);
}

.card-title {
  position: relative;
  margin-top: 24rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.card-desc {
  position: relative;
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 22rpx;
  line-height: 1.45;
}
