.game-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 210rpx;
  min-height: 220rpx;
  vertical-align: top;
}

.icon-stage {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 188rpx;
  height: 132rpx;
  border-radius: 28rpx;
  background:
    linear-gradient(180deg, rgba(10, 10, 45, 0.2), rgba(255, 255, 255, 0.03)),
    rgba(8, 4, 29, 0.42);
}

.card-icon-image {
  width: 154rpx;
  height: 112rpx;
}

.card-title {
  width: 210rpx;
  margin-top: 10rpx;
  color: #f8f7ff;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.2;
  text-align: center;
  text-shadow: 0 0 10rpx rgba(129, 188, 255, 0.48);
  white-space: normal;
}

.card-desc {
  width: 210rpx;
  margin-top: 6rpx;
  color: rgba(221, 217, 244, 0.58);
  font-size: 21rpx;
  font-weight: 600;
  line-height: 1.3;
  text-align: center;
  white-space: normal;
}
