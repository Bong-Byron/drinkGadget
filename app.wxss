page {
  min-height: 100%;
  background: #0A001F;
  color: #ffffff;
  box-sizing: border-box;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  line-height: 1;
  background: transparent;
}

button::after {
  border: 0;
}

.screen {
  min-height: 100vh;
  padding: 36rpx 28rpx 56rpx;
  background: linear-gradient(180deg, #0A001F 0%, #120733 52%, #050011 100%);
}

.page-title {
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 900;
}

.page-subtitle {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 26rpx;
  line-height: 1.5;
}

.section {
  margin-top: 32rpx;
}

.panel {
  padding: 28rpx;
  border: 1rpx solid rgba(0, 229, 255, 0.28);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.06);
}

.result-card {
  margin-top: 28rpx;
  padding: 32rpx;
  border: 1rpx solid rgba(255, 0, 255, 0.36);
  border-radius: 16rpx;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.35;
  text-align: center;
  background: rgba(255, 0, 255, 0.08);
}

.ad-placeholder {
  margin-top: 36rpx;
  height: 108rpx;
  border: 1rpx dashed rgba(0, 229, 255, 0.38);
  border-radius: 16rpx;
  color: rgba(255, 255, 255, 0.52);
  font-size: 24rpx;
  line-height: 106rpx;
  text-align: center;
  background: rgba(0, 229, 255, 0.05);
}

.segmented {
  display: flex;
  gap: 16rpx;
}

.segmented-item {
  flex: 1;
  height: 76rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 16rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 26rpx;
  line-height: 76rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.06);
}

.segmented-item.active {
  color: #081022;
  border-color: #00E5FF;
  background: #00E5FF;
  box-shadow: 0 0 24rpx rgba(0, 229, 255, 0.42);
}
